# =============================================
#  iTrucking Fleet Care — Environment Variables
# =============================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fleet_care
DB_USER=root
DB_PASSWORD=

# --- JWT Auth ---
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# --- Email (for invoices & order confirmations) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# --- Invoice Settings ---
INVOICE_DUE_DAYS=30
INVOICE_PREFIX=FC-
COMPANY_NAME=iTrucking Fleet Care
COMPANY_ADDRESS=Sacramento, CA
COMPANY_PHONE=
COMPANY_EMAIL=billing@fleetcare.com
COMPANY_TAX_ID=

# --- AWS (for file storage / hosting) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
AWS_S3_BUCKET=

# --- Frontend ---
REACT_APP_API_URL=http://localhost:5000/api

# --- Admin ---
ADMIN_EMAIL=admin@fleetcare.com
